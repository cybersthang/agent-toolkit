{
  "_doc": "Intent → skill routing table read by .claude/hooks/intent_router.py. Each entry has a regex (matched case-insensitive on the user's prompt) and a list of skill names. Skill names must match the on-disk skill folder names. Odoo skills are now version-aware (single skill per topic, runtime version detection via __manifest__.py) — no version placeholder needed.",
  "_schema": {
    "stack": "stack identifier — kept for backward compat with hooks reading this field (e.g. 'odoo-12'). Odoo skill names no longer interpolate it.",
    "stack_bare": "bare stack name (kept for backward compat).",
    "entries": "list of {pattern, skills, note?}"
  },
  "stack": "odoo",
  "stack_bare": "odoo",
  "entries": [
    {
      "note": "Clarification gate — action verbs that mutate state",
      "pattern": "\\b(implement|build|deploy|sửa|fix|refactor|tạo|viết|làm|thêm|add|remove|xóa|delete|update|cập\\s*nhật|đổi|change|modify|tối\\s*ưu|optimize|migrate|chuyển|rewrite|làm\\s*lại|làm\\s*gọn|dọn|clean\\s*up|move|rename|extract|inline)\\b",
      "skills": ["clarification-gate"]
    },
    {
      "note": "Clarification gate — ambiguous reference triggers",
      "pattern": "(\\b\\d+\\s*(cái|cái này|cái kia|thằng|thằng này|thằng kia|items?|things?|cụm|chỗ)\\b|\\b2\\s*cái\\s*này\\b|\\bcái\\s*này\\b|\\bcái\\s*kia\\b|\\bchỗ\\s*này\\b|\\bchỗ\\s*kia\\b|\\bnày\\s*khác\\b|\\bcùng\\s*một\\b)",
      "skills": ["clarification-gate"]
    },
    {
      "note": "Review / audit",
      "pattern": "\\b(review|audit|phân\\s*tích\\s*sâu|tìm\\s*bug|kiểm\\s*tra\\s*code|còn\\s*gì.*fix|lỗ\\s*hổng|nguy\\s*hiểm)\\b",
      "skills": ["code-review", "odoo-code-review", "doubt-driven-review"]
    },
    {
      "note": "Doubt-driven probe",
      "pattern": "\\b(double[-\\s]?check|are\\s*you\\s*sure|chắc.*không|chắc.*chưa|sure\\?)\\b",
      "skills": ["doubt-driven-review"]
    },
    {
      "note": "Canonical decision lookup",
      "pattern": "\\b(how\\s*do\\s*we|convention|recurring|canonical|làm\\s*sao.*project|chuẩn.*project|theo\\s*chuẩn)\\b",
      "skills": ["odoo-deterministic-answers"]
    },
    {
      "note": "Codebase discovery",
      "pattern": "\\b(where\\s*is|tìm\\s*file|find.*file|trace.*call|locate|định\\s*nghĩa.*ở\\s*đâu|đọc\\s*hiểu\\s*module)\\b",
      "skills": ["odoo-codebase-discovery"]
    },
    {
      "note": "Debug",
      "pattern": "\\b(bug|lỗi|error|exception|traceback|không\\s*chạy|crash|stuck|treo|hang|fail.*test)\\b",
      "skills": ["odoo-debug-troubleshoot"]
    },
    {
      "note": "Spec Kit Phase 1 — SPECIFY (auto-suggest plan-feature)",
      "pattern": "\\b(/plan\\b|feature\\s*mới|new\\s*feature|tính\\s*năng\\s*mới|thêm.*tính\\s*năng|add.*feature|write\\s*(a\\s*)?prd|create.*spec|tạo\\s*spec)\\b",
      "skills": ["plan-feature"]
    },
    {
      "note": "Spec Kit Phase 2 — CLARIFY",
      "pattern": "\\b(/clarify\\b|grill\\s*me|stress[-\\s]*test\\s*(the\\s*)?spec|challenge\\s*me|đóng\\s*gap|refine\\s*spec)\\b",
      "skills": ["clarify"]
    },
    {
      "note": "Spec Kit Phase 3 — TASKS (manual re-emit)",
      "pattern": "\\b(/tasks\\b|rã\\s*task|task\\s*breakdown|emit\\s*tasks)\\b",
      "skills": ["tasks-breakdown"]
    },
    {
      "note": "Spec Kit Phase 3.5 — ANALYZE",
      "pattern": "\\b(/analyze\\b|cross[-\\s]*artifact|lint\\s*spec|artifact\\s*consistency)\\b",
      "skills": ["analyze-artifacts"]
    },
    {
      "note": "Spec Kit Phase 4 — IMPLEMENT (auto-chain analyze→implement→verify)",
      "pattern": "\\b(/implement\\b|bắt\\s*đầu\\s*code|execute\\s*tasks|start\\s*implement|implement\\s*đi)\\b",
      "skills": ["analyze-artifacts", "verify-feature"]
    },
    {
      "note": "Spec Kit Phase 5 — VERIFY",
      "pattern": "\\b(/verify\\b|real\\s*db|prod\\s*data|verify.*real|kiểm\\s*tra.*dữ\\s*liệu|live\\s*verify|thật\\s*hay\\s*không|any\\s*gaps?|còn\\s*gap)\\b",
      "skills": ["verify-feature", "odoo-data-verification"]
    },
    {
      "note": "Classifier / count-and-classify / prove-tag → real-data-proof workflow (DEV pattern: BLOCK/ASYNC sleep-injection on real data). Pulls in claim-falsification (recipe catalog) + classifier-output-audit (mis-tag finder).",
      "pattern": "\\b(classify|classification|phân\\s*loại|tag\\s*(each|every|từng)|gán\\s*nhãn|nhãn\\s*nào|block\\s*vs\\s*async|block\\s*hay\\s*async|sync\\s*vs\\s*async|prove.*(tag|label|classification)|chứng\\s*minh.*(tag|nhãn|đúng)|falsif(y|ication)|perturb[-\\s]?test|inverse\\s*perturb|count.*requests?.*(classify|tag|phân\\s*loại)|đếm.*request.*phân\\s*loại|sleep\\s*inject|inject\\s*sleep)\\b",
      "skills": ["real-data-proof", "claim-falsification", "classifier-output-audit"]
    },
    {
      "note": "Module scaffold (after spec exists)",
      "pattern": "\\b(tạo\\s*module|scaffold|new\\s*module|module\\s*mới)\\b",
      "skills": ["plan-feature", "odoo-module-scaffold"]
    },
    {
      "note": "TDD",
      "pattern": "\\b(tdd|test\\s*driven|viết\\s*test\\s*trước|test\\s*first|red.*green.*refactor)\\b",
      "skills": ["odoo-tdd"]
    },
    {
      "note": "Stack code patterns",
      "pattern": "\\b(theo\\s*pattern|follow.*style|tuân.*chuẩn|project\\s*style|code\\s*style)\\b",
      "skills": ["odoo-code-patterns"]
    },
    {
      "note": "Toolkit-meta: /adr-add",
      "pattern": "\\b(ghi\\s*adr|thêm\\s*quyết\\s*định|append\\s*adr|architecture\\s*decision|ghi\\s*nhận\\s*decision|chốt\\s*decision)\\b",
      "skills": ["adr-add"]
    },
    {
      "note": "Toolkit-meta: /inv-add",
      "pattern": "\\b(thêm\\s*invariant|add.*invariant|register\\s*rule|đăng\\s*ký\\s*rule|chốt\\s*rule|must[-\\s]*keep)\\b",
      "skills": ["inv-add"]
    },
    {
      "note": "Toolkit-meta: /inv-list",
      "pattern": "\\b(xem\\s*invariant|list.*invariant|danh\\s*sách\\s*invariant|liệt\\s*kê.*rule|active\\s*rules)\\b",
      "skills": ["inv-list"]
    },
    {
      "note": "Toolkit-meta: /recall",
      "pattern": "\\b(recall|nhớ\\s*lại|tìm\\s*quyết\\s*định|trước\\s*đây\\s*chốt|chuyện\\s*gì.*adr|đã\\s*chốt\\s*gì)\\b",
      "skills": ["recall"]
    },
    {
      "note": "Toolkit-meta: /stop-autonomy",
      "pattern": "\\b(tắt\\s*autonomy|dừng\\s*autonomy|stop[-\\s]*autonomy|cắt\\s*autonomy|kết\\s*thúc\\s*autonomy)\\b",
      "skills": ["stop-autonomy"]
    },
    {
      "note": "Toolkit-meta: /tdd toggle",
      "pattern": "\\b(toggle\\s*tdd|/tdd\\s+(on|off|status)|tdd\\s*loop|tdd\\s*config|nudge\\s*pytest)\\b",
      "skills": ["tdd"]
    },
    {
      "note": "Toolkit-meta: /test-env (Change 2 — auto-chain trigger). DEV provides test environment URL → /grill auto-captures + auto-chains to /go. Bare URL alone không match; phải có context 'test'/'môi trường'/'sandbox' để tránh false-positive với URL trong git push / GitHub link.",
      "pattern": "\\b(test\\s*env|môi\\s*trường\\s*test|test\\s*url|test\\s*server|server\\s*test|sandbox\\s*url|đăng\\s*nhập\\s*test|môi\\s*trường\\s*staging|staging\\s*server)\\b",
      "skills": ["test-env"]
    },
    {
      "note": "Jira / ticket",
      "pattern": "\\b(jira|nkv[-\\s]?\\d+|ticket|sprint)\\b",
      "skills": ["odoo-jira-workflow"]
    }
  ]
}
