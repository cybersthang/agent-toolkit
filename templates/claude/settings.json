{
  "_doc": "Project-scoped Claude Code settings managed by agent-toolkit. Edit `.claude/settings.local.json` for per-developer overrides (gitignored). Re-run `setup.py update` to refresh.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/session_brief.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/intent_router.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/invariant_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/analyze_halt_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/spec_first_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/implement_snapshot_hook.py",
            "timeout": 8
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/probe_autostub.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/tdd_runner.py",
            "timeout": 35
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/verification_loop.py",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/verify_nudge.py",
            "timeout": 5
          },
          {
            "_comment": "P5 v0.8.0: timeout reduced 600→120 to prevent 10-minute blocks on hanging MCP",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/auto_test_runner.py",
            "timeout": 150
          },
          {
            "_comment": "P5 v0.8.0: timeout reduced 300→90",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/auto_run_probes.py",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/daemon_manager.py",
            "timeout": 90
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "_comment": "P1 v0.8.0: orchestrator moved to position 1 so audit fires before blocking hooks (closes F1 cascade)",
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/implement_orchestrator.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/evidence_audit.py",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/verify_lint.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/post_edit_verify_gate.py",
            "timeout": 6
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/debug_sentry.py",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/spec_drift_advisory.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/implement_notes_gate.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "{{PYTHON_BIN}} {{WORKSPACE_ROOT}}/.claude/hooks/verify_lint_scope.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
