# Local credentials for this workspace. Copy to `.codex/mcp.local.env` and
# fill in real values. THIS FILE IS GITIGNORED. Never commit secrets.
#
# Env-var prefix for this project: `{{ENV_PREFIX}}` (derived from project
# name; override via `agent-toolkit.config.json` if needed).

# --- Postgres ---
{{ENV_PREFIX}}_PSQL_BIN={{PSQL_BIN}}
{{ENV_PREFIX}}_PGHOST=127.0.0.1
{{ENV_PREFIX}}_PGPORT={{DEFAULT_PG_PORT}}
{{ENV_PREFIX}}_PGUSER=replace-me
{{ENV_PREFIX}}_PGPASSWORD=replace-me
{{ENV_PREFIX}}_PGADMIN_DB=postgres
{{ENV_PREFIX}}_PGDATABASE={{DEFAULT_DB}}

# --- Python venv (project) ---
# Points at the venv binary, not the system Python. Same value the toolkit
# detected/asked for at install time.
{{ENV_PREFIX}}_PYTHON_BIN={{PYTHON_BIN}}

# --- Odoo (only used when running smoke tests / module reload) ---
{{ENV_PREFIX}}_ODOO_BIN=odoo-bin
{{ENV_PREFIX}}_ODOO_CONF=odoo.conf

# --- Odoo-style aliases (optional; postgres wrapper maps these onto the
#     prefixed env vars above). Useful when copying from an existing odoo.conf:
# db_host=localhost
# db_port=5432
# db_user=odoo
# db_password=replace-me
# http_port=8069

# --- JIRA: generic fallback ---
# Used when no profile-specific override is set below.
{{ENV_PREFIX}}_JIRA_BASE_URL=https://jira.example.test/
{{ENV_PREFIX}}_JIRA_USER=replace-me
{{ENV_PREFIX}}_JIRA_PASSWORD=replace-me

# --- JIRA Production profile ---
# Mapped to `{{ENV_PREFIX}}_JIRA_*` by `start_jira_production_mcp.py`.
{{ENV_PREFIX}}_JIRA_PRODUCTION_BASE_URL=https://jira.example.test/
{{ENV_PREFIX}}_JIRA_PRODUCTION_USER=replace-me
{{ENV_PREFIX}}_JIRA_PRODUCTION_PASSWORD=replace-me

# --- JIRA Pre-Production profile ---
# Mapped to `{{ENV_PREFIX}}_JIRA_*` by `start_jira_preproduction_mcp.py`.
{{ENV_PREFIX}}_JIRA_PREPRODUCTION_BASE_URL=https://jira-staging.example.test/
{{ENV_PREFIX}}_JIRA_PREPRODUCTION_USER=replace-me
{{ENV_PREFIX}}_JIRA_PREPRODUCTION_PASSWORD=replace-me

# --- Addon roots override (optional) ---
# Comma-separated list overriding the toolkit preset defaults. Uncomment to
# customize without re-running setup.py.
# {{ENV_PREFIX}}_ADDON_ROOTS={{ADDON_ROOTS_CSV}}
