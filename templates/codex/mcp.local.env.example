NAKIVO_PSQL_BIN=D:\PostgreSQL\17\bin\psql.exe
NAKIVO_PGHOST=127.0.0.1
NAKIVO_PGPORT=5433
NAKIVO_PGUSER=nakivo
NAKIVO_PGPASSWORD=replace-me
NAKIVO_PGADMIN_DB=postgres
NAKIVO_PGDATABASE=Nakivo01
# Project Python: Odoo 12 venv (Python 3.8). MUST point at the venv binary, not the system Python.
NAKIVO_PYTHON_BIN=C:\Users\thang.vo\Desktop\NAKIVO\venv\Scripts\python.exe
NAKIVO_ODOO_BIN=nakivo-server\odoo-bin
NAKIVO_ODOO_CONF=odoo-12-enterprise-master\odoo.conf

# Odoo-style aliases also work in .codex/mcp.local.env:
# http_port=8069
# db_host=localhost
# db_port=5432
# db_user=odoo
# db_password=replace-me

# JIRA generic fallback (used when no profile-specific override is present)
NAKIVO_JIRA_BASE_URL=http://jira.example.com/
NAKIVO_JIRA_USER=replace-me
NAKIVO_JIRA_PASSWORD=replace-me

# JIRA Production profile (mapped to NAKIVO_JIRA_* by start_jira_production_mcp.py)
NAKIVO_JIRA_PRODUCTION_BASE_URL=http://jira-prod.example.com/
NAKIVO_JIRA_PRODUCTION_USER=replace-me
NAKIVO_JIRA_PRODUCTION_PASSWORD=replace-me

# JIRA Pre-Production profile (mapped to NAKIVO_JIRA_* by start_jira_preproduction_mcp.py)
NAKIVO_JIRA_PREPRODUCTION_BASE_URL=http://jira-preprod.example.com/
NAKIVO_JIRA_PREPRODUCTION_USER=replace-me
NAKIVO_JIRA_PREPRODUCTION_PASSWORD=replace-me
